{
  "name": "be_didongviet",
  "version": "1.0.0",
  "description": "Backend API cho website Di Động Việt, cung cấp các chức năng quản lý sản phẩm, người dùng, đơn hàng, và các tính năng liên quan đến thương mại điện tử.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config jest.config.mjs"
  },
  "keywords": [
    "Node.js",
    "Express",
    "MongoDB",
    "API",
    "E-commerce",
    "Di Động Việt"
  ],
  "author": "Nguyễn Văn Huy Hoàng",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#utils/*.js": "./src/utils/*.js",
    "#middlewares/*.js": "./src/middlewares/*.js",
    "#config/*.js": "./src/config/*.js",
    "#auth/*.js": "./src/modules/Auth/*.js",
    "#account/*.js": "./src/modules/Account/*.js",
    "#category/*.js": "./src/modules/Category/*.js",
    "#product/*.js": "./src/modules/Product/*.js",
    "#cart/*.js": "./src/modules/Cart/*.js",
    "#order/*.js": "./src/modules/Order/*.js",
    "#voucher/*.js": "./src/modules/Voucher/*.js",
    "#blog/*.js": "./src/modules/Blog/*.js",
    "#studentProfile/*.js": "./src/modules/StudentProfile/*.js"
  },
  "dependencies": {
    "bcryptjs": "3.0.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.1",
    "morgan": "1.10.1",
    "multer": "2.1.1",
    "nodemailer": "8.0.7",
    "slugify": "1.6.9"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "eslint": "10.3.0",
    "mongodb-memory-server": "11.1.0",
    "nodemon": "3.1.14",
    "supertest": "7.2.2"
  }
}
